{
  "name": "ninja-media",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Ninja Media plugin for WordPress",
  "files": [
    "assets",
    "core",
    "languages",
    "freemius",
    "includes",
    "models",
    "index.php",
    "ninja-media.php",
    "readme.txt"
  ],
  "scripts": {
    "dev-admin": "webpack serve --config webpack.dev.config.js",
    "build-admin": "webpack --config webpack.prod.config.js",
    "watch-assets": "wp-scripts start --config webpack.dev.config.js",
    "watch-sass": "node scripts/watch-css.js",
    "buildSass": "sass source/assets/sass:assets/css --style=compressed --no-source-map",
    "buildPostcss": "postcss \"assets/css/**/*.css\" --replace --no-map",
    "start": "concurrently \"npm:watch-*\"",
    "dev-hot": "concurrently \"npm:watch-sass\" \"npm:dev-admin\" ",
    "clean-maps": "node scripts/clean-maps.js",
    "plugin-zip": "wp-scripts plugin-zip",
    "strip-premium": "node scripts/strip-premium.js",
    "zip:free": "node scripts/zip-free.js",
    "build:free": "npm run buildSass && npm run buildPostcss && npm run build-admin && npm run clean-maps && npm run strip-premium && npm run zip:free",
    "build": "npm run buildSass && npm run buildPostcss && concurrently \"npm:build-*\" && npm run clean-maps",
    "build:zip": "npm run build && npm run clean-maps && npm run plugin-zip",
    "build:premium-zip": "npm run buildSass && npm run buildPostcss && npm run build-admin && npm run clean-maps && npm run plugin-zip"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@reduxjs/toolkit": "^2.11.2",
    "@uiw/codemirror-theme-okaidia": "^4.25.4",
    "@uiw/react-codemirror": "^4.25.4",
    "@wordpress/components": "^30.5.0",
    "@wordpress/element": "^6.32.0",
    "@wordpress/i18n": "^6.5.0",
    "clsx": "^2.1.1",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.2"
  },
  "devDependencies": {
    "@types/plupload": "^2.0.14",
    "@wordpress/scripts": "^30.25.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cssnano": "^7.1.1",
    "glob": "^11.0.3",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-preset-env": "^10.4.0",
    "sass": "^1.93.2"
  }
}